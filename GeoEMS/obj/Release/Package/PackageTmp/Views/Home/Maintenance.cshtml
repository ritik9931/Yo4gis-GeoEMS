                <div class="col-md-12 col-sm-12 col-xs-12">
                    <table id="excelDataTabledata" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" width="100%">
                        <thead>
                            <tr><th>Ticket No. </th><th>Vehicle No.</th><th>Created Date and Time</th><th>Action</th></tr>
                        </thead>
                        @*<tbody id="excelDataTabledata"></tbody>*@
                    </table>
