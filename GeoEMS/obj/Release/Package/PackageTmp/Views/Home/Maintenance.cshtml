    <div class="row">


    </div>
</div>
<script>
    GetGpsDataList();
    function GetGpsDataList() {
    let url = "@Url.Action("GetAllTicketData", "Home")";
    $.ajax({
        url: url,
        crossDomain: true,

        success: function (res) {

           // var Result = JSON.parse(data.Data)



            if (res.Data.length == 0) {
                toastr.error('', "Record is empty");
                if ($.fn.DataTable.isDataTable("#excelDataTabledata")) {
                    $('#excelDataTabledata').DataTable().clear().destroy();
                }
            }

            if ($.fn.DataTable.isDataTable('#excelDataTabledata')) {
                $('#excelDataTabledata').DataTable().destroy();
            }

            $('#excelDataTable tbody').empty();



            var tabledata = $('#excelDataTabledata').DataTable({
                data: res.Data,
                "columns": [
                    { "data": "ticket_no" },
                    { "data": "vehicle_no" },
                    //{ "data": "created_at" },
                    {
                        "data": function (data, type, row, meta) {

                            const date1 = moment(data.created_at).format("DD-MM-YYYY HH:mm:ss");
                            return date1;

                        }
                    },
                    {
                        "data": function (data, type, row, meta) {

                            data1 = "<button id='" + data.ticket_no + "' class='btn btn-error btn-xs btn-rounded' onclick=DeleteTrip(this.id) ><span class='glyphicon glyphicon-trash'></span></button>";
                            return data1;

                        }
                    }
                ]


            });
        }

    });


    }

    function DeleteTrip(id) {
        //alert('Hello');

        Swal.fire({
            title: "Are you sure?",
            text: "Do you want to proceed?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes",
            cancelButtonText: "No",
            reverseButtons: true // Puts "No" on the left
        }).then((result) => {
            if (result.isConfirmed) {
                    let url = "@Url.Action("DeleteTripData", "Home")?tripId=" + id;
                        $.ajax({
                    url: url,
                    crossDomain: true,

                    success: function (res) {
                        Swal.fire("Confirmed!", "Data Deleted Successfully.", "success");
                        GetGpsDataList();
                    }
                    
                });

                // Function to execute when "Yes" is clicked
                
                //yesFunction();
            } else {
                // Function to execute when "No" is clicked
                Swal.fire("Cancelled", "You clicked No.", "error");
                //noFunction();
            }
        });




    }
</script>