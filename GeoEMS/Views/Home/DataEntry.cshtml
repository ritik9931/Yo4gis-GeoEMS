        }
        if (errorDateCount != 0) {
            new PNotify({
                title: 'Excel Upload',
                text: 'Please validate records in table',
                type: 'error',
                styling: 'bootstrap3'
            });
            return false;
        } else if (fileInput.value == '') {
            new PNotify({
                title: 'Excel Upload',
                text: 'Please select file',
                type: 'error',
                styling: 'bootstrap3'
            });
            return false;
        }

        else {
            return true;
        }
    }

