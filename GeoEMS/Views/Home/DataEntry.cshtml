
@{
    ViewBag.Title = "DataEntry";

}

@if (TempData["Error"] != null)
{


    <script type="text/javascript">
        var msg = '@TempData["Error"]';
         new PNotify({
         title: 'Excel Upload',
         text: '@TempData["Error"]',
         type: 'info',
         styling: 'bootstrap3'
     });
    </script>

}

@if (TempData["Success"] != null)
{
    <script type="text/javascript">
        var msg = '@TempData["Success"]';
        if (msg.length) {
            new PNotify({
                title: 'Excel Upload',
                text: msg,
                type: 'info',
                styling: 'bootstrap3'
            });
            alert(msg);
    }
    </script>

}
