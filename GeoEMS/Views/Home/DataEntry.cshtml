    function displayData(data) {
        const table = document.getElementById('excelDataTabledata');
        table.innerHTML = ''; // Clear any existing data

        errorDateCount = 0;
        var cntRow = 0;
        // Loop through rows and cells
        data.forEach((row) => {
            cntRow++;
            let rowElement = document.createElement('tr');
            const dateString = row[4];
            const format = "DD-MM-YYYY HH:mm:ss";
            const format1 = "DD/MM/YYYY HH:mm:ss";

            // Validate the date format
            const isValid = moment(dateString, format, true).isValid();
            const isValid1 = moment(dateString, format1, true).isValid();
            if (!(isValid || isValid1) && dateString != 'Geofence Date and Time') {
                rowElement.className = "danger";
                row.push('false');
                errorDateCount = errorDateCount + 1;
            } else {
                row.push('true')
            }
            //alert(); //true
            row.forEach((cell) => {
                let cellElement = document.createElement('td');
                cellElement.textContent = cell;
                rowElement.appendChild(cellElement);
            });
            if (row[0] != 'TicketNo') {

                table.appendChild(rowElement);
            }
        });

        if (errorDateCount > 0) {
            new PNotify({
                title: 'Excel Upload',
                text: errorDateCount + ' :- Number of record are not in correct format. Please check date format',
                type: 'error',
                styling: 'bootstrap3'
            });
        }
    }



    function checkfile(id) {
