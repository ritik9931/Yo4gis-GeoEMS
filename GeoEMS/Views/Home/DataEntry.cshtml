    function displayAfteValidate(exceldata, tabledata) {
        if (exceldata == null) {
            return new PNotify({
                title: 'Excel Validate',
                text: 'Please select excel file.',
                type: 'error',
                styling: 'bootstrap3'
            });
        }

        if ($.fn.DataTable.isDataTable('#excelDataTable')) {
            $('#excelDataTable').DataTable().destroy();
        }

        $('#excelDataTable tbody').empty();


        const table = document.getElementById('excelDataTabledata');
        table.innerHTML = ''; // Clear any existing data

        errorDateCount = 0;
        // Loop through rows and cells
        exceldata.forEach((row) => {
            let rowElement = document.createElement('tr');
            const ticketString = row[0];

            if (tabledata.length > 0) {
                const isAvl = tabledata.find(f => f.ticket_no == ticketString);

                if (isAvl != undefined) {
                    rowElement.className = "danger";
                    errorDateCount = errorDateCount + 1;
                }
            }

            //alert(); //true
            row.forEach((cell) => {
                let cellElement = document.createElement('td');
                cellElement.textContent = cell;
                rowElement.appendChild(cellElement);
            });

            //table.appendChild(rowElement);
            if (row[0] != 'TicketNo') {

                table.appendChild(rowElement);
            }
        });


        // ... skipped ...

        $('#excelDataTable').dataTable();
        //$('#excelDataTable').DataTable();
        if (errorDateCount > 0) {
            new PNotify({
                title: 'Excel Validate',
                text: errorDateCount + ' :- Number of record are duplicate',
                type: 'error',
                styling: 'bootstrap3'
            });
        } else {
            new PNotify({
                title: 'Excel Validate',
                text: ' Validate Successfully',
                type: 'success',
                styling: 'bootstrap3'
            });
        }
    }




    function chkValid() {
